  m_text: "Dlf\xEDn, Delphinus delphis\nMide entre 1,5 - 2,5 m\nH\xE1bitat: Superficie\nEsperanza
    de  vida: 20 - 30 a\xF1os\nDieta: Carn\xEDvora\nCar\xE1cter: Tranquilo\nEstado
    de conservaci\xF3n:\nAmenazado\n\nDATO CURIOSO:\nSon extremadamente inteligentes
    y pueden comunicarse mediante sonidos y gestos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 355857c278d91254eaac9f84b5979225, type: 2}
