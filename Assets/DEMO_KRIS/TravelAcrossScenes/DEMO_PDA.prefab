  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Raya, Dasyatis pastinaca\nMide entre 50 - 2 cm\nH\xE1bitat: Superficie\nEsperanza
    de  vida: 15 - 25 a\xF1os\nDieta: Carn\xEDvora\nCar\xE1cter: Tranquilo\nEstado
    de conservaci\xF3n:\nVulnerable\n\nDATO CURIOSO:\nSu cola tiene una o m\xE1s
    espinas con veneno; puede usarla como defensa."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 355857c278d91254eaac9f84b5979225, type: 2}
